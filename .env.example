# Copy to `.env` for local Vite (`npm run dev` / `npm run build`).
# Anon key is public by design; never put the service role key here.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets,
#     or `supabase secrets set --project-ref YOUR_REF NAME=value`) ---
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET
# APP_BASE_URL              (no trailing slash; production dashboard origin)
# DASHBOARD_ALLOWED_ORIGINS (comma-separated exact origins, e.g. https://app.example.com,http://localhost:5173)
# STRIPE_CONNECT_DEFAULT_COUNTRY (optional, ISO 3166-1 alpha-2, default US in code)
